<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Win John Maxwell's New Book — Free Giveaway</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<script src="https://js.hcaptcha.com/1/api.js" async defer></script>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --dark: #0d0f0e;
    --dark2: #161a18;
    --teal: oklch(72% 0.14 178);
    --teal-bright: oklch(80% 0.16 178);
    --teal-dim: oklch(55% 0.12 178);
    --green: oklch(72% 0.16 152);
    --off-white: #f0ede8;
    --muted: #8a8f8c;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--dark);
    color: var(--off-white);
    font-family: 'DM Sans', sans-serif;
    line-height: 1.6;
    min-height: 100vh;
    overflow-x: hidden;
  }

  body::before {
    content: '';
    position: fixed; inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none; z-index: 0;
  }

  .hero-glow {
    position: absolute;
    top: -120px; left: 50%; transform: translateX(-50%);
    width: 900px; height: 600px;
    background: radial-gradient(ellipse at center, oklch(55% 0.14 178 / 0.22) 0%, transparent 70%);
    pointer-events: none;
  }

  /* Scarcity Banner */
  .scarcity-banner {
    background: linear-gradient(90deg, var(--teal-dim), var(--teal), var(--teal-dim));
    color: #000;
    text-align: center;
    padding: 10px 20px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    position: relative; z-index: 10;
  }

  /* Hero */
  .hero {
    position: relative;
    max-width: 1100px;
    margin: 0 auto;
    padding: 60px 24px 40px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    z-index: 1;
  }

  @media (max-width: 760px) {
    .hero { grid-template-columns: 1fr; gap: 40px; padding: 40px 20px 20px; }
    .hero-book { order: -1; }
  }

  .eyebrow {
    display: inline-flex; align-items: center; gap: 8px;
    background: oklch(55% 0.12 178 / 0.15);
    border: 1px solid oklch(55% 0.12 178 / 0.35);
    color: var(--teal);
    font-size: 11px; font-weight: 600;
    letter-spacing: 0.12em; text-transform: uppercase;
    padding: 6px 14px; border-radius: 100px;
    margin-bottom: 24px;
  }
  .eyebrow-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--teal);
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.7); }
  }

  h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(36px, 5vw, 62px);
    line-height: 1.08;
    font-weight: 900;
    letter-spacing: -0.02em;
    text-wrap: balance;
    margin-bottom: 20px;
  }
  h1 em {
    font-style: normal;
    background: linear-gradient(135deg, var(--teal), var(--green));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subhead {
    font-size: 17px;
    color: #b0b8b4;
    font-weight: 300;
    margin-bottom: 32px;
    max-width: 420px;
    text-wrap: pretty;
  }

  .bullets { list-style: none; margin-bottom: 36px; display: flex; flex-direction: column; gap: 12px; }
  .bullets li {
    display: flex; align-items: flex-start; gap: 12px;
    font-size: 15px; color: #c8d0cc;
  }
  .bullet-icon {
    flex-shrink: 0; width: 20px; height: 20px; margin-top: 1px;
    background: linear-gradient(135deg, var(--teal), var(--green));
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
  }
  .bullet-icon svg { width: 10px; height: 10px; }

  /* Countdown */
  .countdown-wrap {
    display: flex; gap: 12px; align-items: center;
    margin-bottom: 36px;
  }
  .countdown-label {
    font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em;
    color: var(--muted); white-space: nowrap;
  }
  .countdown-blocks { display: flex; gap: 6px; }
  .cd-block {
    background: #1d2220;
    border: 1px solid #2a3030;
    border-radius: 6px;
    padding: 6px 10px;
    text-align: center;
    min-width: 48px;
  }
  .cd-num {
    font-size: 20px; font-weight: 700; line-height: 1;
    font-variant-numeric: tabular-nums;
    color: var(--teal);
    display: block;
  }
  .cd-unit { font-size: 9px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.08em; }

  /* Hero CTA */
  .hero-cta {
    display: inline-flex; align-items: center; gap: 10px;
    background: linear-gradient(135deg, var(--teal), var(--green));
    color: #000; font-weight: 700; font-size: 16px;
    padding: 16px 28px; border-radius: 8px; text-decoration: none;
    transition: transform 0.15s, filter 0.15s, box-shadow 0.15s;
  }
  .hero-cta:hover {
    transform: translateY(-1px);
    filter: brightness(1.08);
    box-shadow: 0 8px 30px oklch(55% 0.14 178 / 0.4);
  }

  /* Book */
  .hero-book {
    display: flex; justify-content: center; align-items: center;
    position: relative;
  }
  .book-wrap {
    position: relative;
    filter: drop-shadow(0 40px 80px oklch(55% 0.14 178 / 0.3)) drop-shadow(0 0 120px oklch(40% 0.1 178 / 0.2));
    animation: float 5s ease-in-out infinite;
  }
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }
  .book-wrap img { width: 100%; max-width: 340px; display: block; }
  .copies-badge {
    position: absolute;
    top: -16px; right: -16px;
    background: linear-gradient(135deg, var(--teal), var(--green));
    color: #000;
    font-weight: 700; font-size: 12px;
    padding: 8px 14px; border-radius: 100px;
    box-shadow: 0 4px 20px oklch(55% 0.14 178 / 0.5);
    white-space: nowrap;
  }

  /* Credentials Bar */
  .cred-bar {
    position: relative; z-index: 1;
    border-top: 1px solid #1e2422;
    border-bottom: 1px solid #1e2422;
    padding: 18px 24px;
    display: flex; align-items: center; justify-content: center;
    gap: 32px; flex-wrap: wrap;
    background: #0f1210;
  }
  .cred-item {
    font-size: 13px; color: var(--muted);
    display: flex; align-items: center; gap: 8px;
  }
  .cred-item strong { color: var(--off-white); font-weight: 600; }
  .cred-divider { width: 1px; height: 28px; background: #1e2422; }
  @media (max-width: 560px) { .cred-divider { display: none; } }

  /* Form Section */
  .form-section {
    position: relative; z-index: 1;
    background: linear-gradient(180deg, #0d0f0e 0%, #111614 100%);
    border-top: 1px solid #1e2422;
    padding: 60px 24px 80px;
  }
  .form-inner {
    max-width: 540px;
    margin: 0 auto;
    text-align: center;
  }
  .form-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(26px, 4vw, 42px);
    font-weight: 700;
    margin-bottom: 10px;
    text-wrap: balance;
  }
  .form-sub {
    color: var(--muted);
    font-size: 15px;
    margin-bottom: 36px;
  }
  .form-sub strong { color: var(--teal); font-weight: 600; }

  .form-card {
    background: #141917;
    border: 1px solid #242c28;
    border-radius: 16px;
    padding: 36px 32px;
    text-align: left;
  }

  .field { margin-bottom: 18px; }
  .field label {
    display: block;
    font-size: 12px; font-weight: 600;
    letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--muted); margin-bottom: 8px;
  }
  .field input {
    width: 100%;
    background: #0d0f0e;
    border: 1px solid #2a3230;
    border-radius: 8px;
    padding: 14px 16px;
    font-size: 16px;
    color: var(--off-white);
    font-family: 'DM Sans', sans-serif;
    transition: border-color 0.2s, box-shadow 0.2s;
    outline: none;
  }
  .field input::placeholder { color: #4a5450; }
  .field input:focus {
    border-color: var(--teal-dim);
    box-shadow: 0 0 0 3px oklch(55% 0.12 178 / 0.12);
  }
  .field input.error { border-color: oklch(65% 0.18 20); }

  .field-error {
    font-size: 12px; color: oklch(65% 0.18 20);
    margin-top: 4px; display: none;
  }
  .field-error.visible { display: block; }

  .hcaptcha-wrap { margin-bottom: 18px; }

  .submit-btn {
    width: 100%;
    padding: 17px 24px;
    background: linear-gradient(135deg, var(--teal), var(--green));
    color: #000; border: none; border-radius: 8px;
    font-size: 17px; font-weight: 700;
    font-family: 'DM Sans', sans-serif;
    cursor: pointer; letter-spacing: -0.01em;
    transition: transform 0.15s, filter 0.15s, box-shadow 0.15s;
    margin-top: 6px;
  }
  .submit-btn:hover { transform: translateY(-1px); filter: brightness(1.08); box-shadow: 0 8px 30px oklch(55% 0.14 178 / 0.4); }
  .submit-btn:active { transform: translateY(0); }
  .submit-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; filter: none; box-shadow: none; }

  .server-error {
    font-size: 13px; color: oklch(65% 0.18 20);
    text-align: center; margin-top: 12px; display: none;
  }
  .server-error.visible { display: block; }

  .privacy-note {
    font-size: 12px; color: #4a5450;
    text-align: center; margin-top: 16px;
    display: flex; align-items: center; justify-content: center; gap: 6px;
  }

  /* Success State */
  .success-state {
    display: none;
    text-align: center;
    padding: 20px 0;
  }
  .success-icon {
    width: 72px; height: 72px; margin: 0 auto 20px;
    background: linear-gradient(135deg, var(--teal), var(--green));
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
  }
  .success-icon svg { width: 32px; height: 32px; }
  .success-title {
    font-family: 'Playfair Display', serif;
    font-size: 28px; font-weight: 700; margin-bottom: 10px;
  }
  .success-body { color: var(--muted); font-size: 15px; max-width: 360px; margin: 0 auto; }
</style>
</head>
<body>

<div class="scarcity-banner">
  🎁 &nbsp;Free Giveaway — Only 10 Copies Available &nbsp;·&nbsp; Enter Before Spots Run Out
</div>

<section style="position:relative; overflow:hidden;">
  <div class="hero-glow"></div>
  <div class="hero">

    <div class="hero-copy">
      <div class="eyebrow">
        <span class="eyebrow-dot"></span>
        LinkedIn Exclusive Giveaway
      </div>

      <h1>
        Turn Every<br>
        <em>Setback Into</em><br>
        Your Greatest<br>
        Advantage
      </h1>

      <p class="subhead">
        Win one of <strong style="color:var(--off-white)">10 free copies</strong> of John C. Maxwell's new book — the playbook for leaders who refuse to let failure be the final word.
      </p>

      <ul class="bullets">
        <li>
          <span class="bullet-icon"><svg viewBox="0 0 10 8" fill="none"><path d="M1 4l2.5 2.5L9 1" stroke="#000" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          From the #1 <em>New York Times</em> bestselling author &amp; leadership icon
        </li>
        <li>
          <span class="bullet-icon"><svg viewBox="0 0 10 8" fill="none"><path d="M1 4l2.5 2.5L9 1" stroke="#000" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          A proven framework to fail smarter and return stronger
        </li>
        <li>
          <span class="bullet-icon"><svg viewBox="0 0 10 8" fill="none"><path d="M1 4l2.5 2.5L9 1" stroke="#000" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
          Brand-new release — be among the first to read it
        </li>
      </ul>

      <div class="countdown-wrap">
        <span class="countdown-label">Contest closes in</span>
        <div class="countdown-blocks">
          <div class="cd-block"><span class="cd-num" id="cd-d">--</span><span class="cd-unit">days</span></div>
          <div class="cd-block"><span class="cd-num" id="cd-h">--</span><span class="cd-unit">hrs</span></div>
          <div class="cd-block"><span class="cd-num" id="cd-m">--</span><span class="cd-unit">min</span></div>
          <div class="cd-block"><span class="cd-num" id="cd-s">--</span><span class="cd-unit">sec</span></div>
        </div>
      </div>

      <a href="#enter" class="hero-cta">
        Enter to Win — It's Free
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="#000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>

    <div class="hero-book">
      <div class="book-wrap">
        <span class="copies-badge">10 Copies Up For Grabs</span>
        <img src="/book-cover.png" alt="How to Get a Return on Failure by John C. Maxwell">
      </div>
    </div>

  </div>
</section>

<div class="cred-bar">
  <div class="cred-item"><strong>100M+</strong> books sold worldwide</div>
  <div class="cred-divider"></div>
  <div class="cred-item"><strong>#1</strong> NYT Bestselling Author</div>
  <div class="cred-divider"></div>
  <div class="cred-item"><strong>5×</strong> decades of leadership wisdom</div>
  <div class="cred-divider"></div>
  <div class="cred-item">Forbes' <strong>Top Leadership Influencer</strong></div>
</div>

<section class="form-section" id="enter">
  <div class="form-inner">

    <h2 class="form-title">Claim Your Spot in the Giveaway</h2>
    <p class="form-sub">
      Just fill in your details below. <strong>10 winners</strong> will be selected at random and notified by email.
    </p>

    <div class="form-card">
      <div id="form-state">
        <div class="field">
          <label for="f-name">Full Name</label>
          <input type="text" id="f-name" placeholder="e.g. Alex Johnson" autocomplete="name">
          <div class="field-error" id="name-err">Please enter your first and last name.</div>
        </div>

        <div class="field">
          <label for="f-email">Email Address</label>
          <input type="email" id="f-email" placeholder="you@example.com" autocomplete="email">
          <div class="field-error" id="email-err">Please enter a valid email address.</div>
        </div>

        <div class="field">
          <label for="f-mobile">Mobile Number</label>
          <input type="tel" id="f-mobile" placeholder="+1 (555) 000-0000" autocomplete="tel">
          <div class="field-error" id="mobile-err">Please enter a valid mobile number.</div>
        </div>

        <div class="hcaptcha-wrap">
          <div class="h-captcha" data-sitekey="<%= hcaptchaSiteKey %>"></div>
          <div class="field-error visible" id="captcha-err" style="display:none">Please complete the CAPTCHA.</div>
        </div>

        <button class="submit-btn" id="submit-btn" onclick="handleSubmit()">
          Enter to Win My Free Copy →
        </button>

        <div class="server-error" id="server-err"></div>

        <p class="privacy-note">
          <svg width="12" height="14" viewBox="0 0 12 14" fill="none"><path d="M6 1L1 3v4c0 3 2.5 5.5 5 6 2.5-.5 5-3 5-6V3L6 1z" stroke="#4a5450" stroke-width="1.2" stroke-linejoin="round"/></svg>
          No spam. Your info is never sold or shared.
        </p>
      </div>

      <div class="success-state" id="success-state">
        <div class="success-icon">
          <svg viewBox="0 0 32 32" fill="none"><path d="M6 16l7 7L26 9" stroke="#000" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="success-title">You're entered! 🎉</div>
        <p class="success-body" id="success-body">
          Thanks for entering. If you're one of our 10 lucky winners, we'll reach out to the email you provided. Good luck!
        </p>
      </div>
    </div>

  </div>
</section>

<script>
// Countdown — persists across reloads via localStorage
const endTime = (() => {
  const stored = localStorage.getItem('maxwell-end');
  if (stored) return parseInt(stored);
  const t = Date.now() + 7 * 24 * 60 * 60 * 1000;
  localStorage.setItem('maxwell-end', t);
  return t;
})();

function updateCountdown() {
  const diff = Math.max(0, endTime - Date.now());
  const d = Math.floor(diff / 86400000);
  const h = Math.floor((diff % 86400000) / 3600000);
  const m = Math.floor((diff % 3600000) / 60000);
  const s = Math.floor((diff % 60000) / 1000);
  document.getElementById('cd-d').textContent = String(d).padStart(2,'0');
  document.getElementById('cd-h').textContent = String(h).padStart(2,'0');
  document.getElementById('cd-m').textContent = String(m).padStart(2,'0');
  document.getElementById('cd-s').textContent = String(s).padStart(2,'0');
}
updateCountdown();
setInterval(updateCountdown, 1000);

// Show success state if already entered
if (localStorage.getItem('maxwell-entered') === '1') {
  document.getElementById('form-state').style.display = 'none';
  document.getElementById('success-state').style.display = 'block';
}

// Mobile input — strip non-phone chars
document.getElementById('f-mobile').addEventListener('input', function() {
  this.value = this.value.replace(/[^\d+\s\-\(\)]/g, '');
});

function setError(inputId, errId, show) {
  document.getElementById(inputId).classList.toggle('error', show);
  document.getElementById(errId).classList.toggle('visible', show);
}

async function handleSubmit() {
  const nameEl   = document.getElementById('f-name');
  const emailEl  = document.getElementById('f-email');
  const mobileEl = document.getElementById('f-mobile');
  const btn      = document.getElementById('submit-btn');
  const serverErr = document.getElementById('server-err');

  serverErr.classList.remove('visible');

  const emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  const phoneRe = /^[\+\d][\d\s\-\(\)]{7,}$/;
  const nameParts = nameEl.value.trim().split(/\s+/);

  let valid = true;
  setError('f-name',   'name-err',   nameParts.length < 2 || !nameEl.value.trim());
  setError('f-email',  'email-err',  !emailRe.test(emailEl.value.trim()));
  setError('f-mobile', 'mobile-err', !phoneRe.test(mobileEl.value.trim()));
  if (nameParts.length < 2 || !nameEl.value.trim()) valid = false;
  if (!emailRe.test(emailEl.value.trim())) valid = false;
  if (!phoneRe.test(mobileEl.value.trim())) valid = false;

  // hCaptcha check
  const htoken = hcaptcha.getResponse();
  if (!htoken) {
    document.getElementById('captcha-err').style.display = 'block';
    valid = false;
  } else {
    document.getElementById('captcha-err').style.display = 'none';
  }

  if (!valid) return;

  btn.disabled = true;
  btn.textContent = 'Entering…';

  try {
    const res = await fetch('/enter', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        name:   nameEl.value.trim(),
        email:  emailEl.value.trim(),
        mobile: mobileEl.value.trim(),
        'h-captcha-response': htoken,
      }),
    });
    const data = await res.json();

    if (res.status === 409) {
      // Already entered — just show success
      showSuccess(nameParts[0], emailEl.value.trim());
      return;
    }

    if (!res.ok) {
      serverErr.textContent = data.error || 'Something went wrong. Please try again.';
      serverErr.classList.add('visible');
      btn.disabled = false;
      btn.textContent = 'Enter to Win My Free Copy →';
      hcaptcha.reset();
      return;
    }

    localStorage.setItem('maxwell-entered', '1');
    showSuccess(data.firstName, emailEl.value.trim());

  } catch {
    serverErr.textContent = 'Network error — please check your connection and try again.';
    serverErr.classList.add('visible');
    btn.disabled = false;
    btn.textContent = 'Enter to Win My Free Copy →';
    hcaptcha.reset();
  }
}

function showSuccess(firstName, email) {
  document.getElementById('form-state').style.display = 'none';
  const ss = document.getElementById('success-state');
  ss.style.display = 'block';
  document.getElementById('success-body').textContent =
    `Thanks, ${firstName}! If you're one of our 10 lucky winners, we'll reach out to ${email}. Good luck!`;
}
</script>
</body>
</html>
